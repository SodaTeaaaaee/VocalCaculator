import { Slider } from "std-widgets.slint";
import { SkeuBtn } from "components/button.slint";
import { LcdDisplay } from "components/display.slint";
import { StatusBar } from "components/status-bar.slint";
import { NetworkPanel } from "components/network-panel.slint";
import { SettingsPanel } from "components/settings-panel.slint";
import { AboutDialog } from "components/about-dialog.slint";
import { PeerInfoSlint } from "theme.slint";

// =====================================================================
// Skeuomorphic Calculator – GridLayout-based adaptive layout
// Inspired by Casio SL-300 / Eltex 2000 / Neumorphic calculators
// =====================================================================

// ---- Main calculator window ----
export component CalculatorWindow inherits Window {
    default-font-family: "Noto Sans SC";
    preferred-width: 380px;
    preferred-height: 700px;
    min-width: 260px;
    min-height: 460px;
    title: "语音计算器";
    forward-focus: kbd-focus;

    // App version (set from Rust at runtime)
    in property <string> app-version: "v0.1.0";

    // ---- Scalable font sizes (derived from window height, with floor) ----
    property <length> btn-font-size: Math.max(12px, self.height * 0.025);
    property <length> lcd-font-size: Math.max(16px, self.height * 0.04);
    property <length> status-font-size: Math.max(10px, self.height * 0.022);
    property <length> icon-font-size: Math.max(20px, self.height * 0.04);
    property <length> brand-font-size: Math.max(10px, self.height * 0.02);

    // ---- Scalable layout dimensions (all proportional to window height) ----
    property <length> body-margin: Math.max(4px, self.height * 0.014);
    property <length> inner-margin: Math.max(2px, self.height * 0.004);
    property <length> solar-h: Math.max(4px, self.height * 0.014);
    property <length> brand-h: Math.max(8px, self.height * 0.023);
    property <length> status-h: Math.max(24px, self.height * 0.055);
    property <length> icon-sz: Math.max(36px, self.height * 0.075);
    property <length> status-icon-sz: Math.max(18px, self.height * 0.035);
    property <length> volume-h: Math.max(20px, self.height * 0.045);
    property <length> history-h: Math.max(10px, self.height * 0.022);
    property <length> lcd-h: Math.max(40px, self.height * 0.1);
    property <length> layout-spacing: Math.max(2px, self.height * 0.005);
    property <length> layout-padding: Math.max(4px, self.height * 0.011);

    // Theme
    in-out property <bool> dark-mode: false;
    background: dark-mode ? #1a1a1e : #e8e4e0;

    // Data properties
    in property <string> display-text: "0";
    in property <string> memory-indicator: "";
    in property <string> mode-indicator: "普通";
    in property <bool> error-state: false;
    in property <string> history-text: "";
    in property <string> audio-status: "";
    in-out property <bool> audio-muted: false;

    // Keyboard visual feedback: set by FocusScope on key-press/release
    in-out property <string> last-keyboard-action: "";
    in-out property <bool> keyboard-pressed: false;

    // Network status
    in property <string> network-status: "";
    in property <bool> remote-controlled: false;
    in property <bool> executing-remotely: false;
    in property <string> connection-info: "";
    in property <bool> network-panel-visible: false;
    in property <[PeerInfoSlint]> peers;
    in property <int> connected-peer-index: -1;
    in property <bool> scanning: false;
    in-out property <bool> allow-remote-control: true;

    // About dialog visibility
    in-out property <bool> about-visible: false;

    // Settings panel
    in property <bool> settings-panel-visible: false;
    in property <string> settings-display-name: "";
    in property <string> settings-save-status: "";

    // Routing matrix
    in property <int> matrix-size: 0;
    in property <[string]> peer-names: [];
    in property <int> my-index: -1;
    in property <[bool]> matrix-cells: [];
    callback route-toggled(int, int, bool);

    // ---- Skeuomorphic color palette ----
    property <brush> body-fill: dark-mode ? #2a2a30 : #c0bab4;
    property <brush> body-edge: dark-mode ? #3a3a42 : #a8a29c;
    property <brush> body-inner: dark-mode ? #222228 : #d4cec8;
    property <brush> lcd-bg: dark-mode ? #2a3a2a : #b8c890;
    property <brush> lcd-fg: dark-mode ? #a0d0a0 : #2a3a1a;
    property <brush> lcd-frame: dark-mode ? #1a1a20 : #606850;
    property <brush> lcd-error-bg: dark-mode ? #3a2020 : #e8b0a0;
    property <brush> lcd-error-fg: dark-mode ? #ff8080 : #8a2020;
    property <brush> solar-fill: dark-mode ? #0a0a12 : #1a1a2a;
    property <brush> solar-cell: dark-mode ? #1a1a28 : #0a0a18;
    property <brush> btn-digit: dark-mode ? #3a3a42 : #d8d4d0;
    property <brush> btn-digit-fg: dark-mode ? #d0d0d0 : #2a2a2a;
    property <brush> btn-op: dark-mode ? #5a4020 : #e8a848;
    property <brush> btn-op-fg: dark-mode ? #ffd090 : #3a2a10;
    property <brush> btn-func: dark-mode ? #303038 : #b0aca8;
    property <brush> btn-func-fg: dark-mode ? #a0a0a0 : #4a4a4a;
    property <brush> btn-clear: dark-mode ? #5a2020 : #d06050;
    property <brush> btn-clear-fg: dark-mode ? #ffaaaa : #ffffff;
    property <brush> btn-ci: dark-mode ? #4a3520 : #d08868;
    property <brush> btn-ci-fg: dark-mode ? #ffccaa : #ffffff;
    property <brush> btn-bs: dark-mode ? #4a4020 : #d0b870;
    property <brush> btn-bs-fg: dark-mode ? #ffddaa : #3a2a10;
    property <brush> btn-eq: dark-mode ? #1a4070 : #4080c8;
    property <brush> btn-eq-fg: dark-mode ? #90c0ff : #ffffff;
    property <brush> btn-memory: dark-mode ? #4a2020 : #c04040;
    property <brush> status-fg: dark-mode ? #808090 : #706860;
    property <brush> status-hover: dark-mode ? #3a3a42 : #c0bab4;

    // Callbacks
    callback digit-pressed(int);
    callback decimal-point();
    callback operator-pressed(string);
    callback equals();
    callback percent();
    callback mu();
    callback square-root();
    callback backspace();
    callback clear-input();
    callback all-clear();
    callback plus-minus();
    callback memory-recall();
    callback memory-add();
    callback memory-subtract();
    callback memory-clear();
    callback switch-audio-mode();
    callback show-about();
    callback close-about();
    callback toggle-theme();
    callback volume-changed(float);
    callback toggle-mute();
    callback show-settings();
    callback close-settings();
    callback save-display-name(string);
    callback show-network-settings();
    callback close-network-settings();
    callback connect-to-peer(string);
    callback disconnect-peer(string);
    callback scan-peers();
    callback toggle-remote-control();
    callback keyboard-action(string);

    // =================================================================
    // Body
    // =================================================================
    Rectangle {
        x: root.body-margin; y: root.body-margin;
        width: parent.width - 2 * root.body-margin;
        height: parent.height - 2 * root.body-margin;
        property <length> body-r: Math.min(self.width, self.height) * 0.03;
        border-radius: self.body-r;
        background: root.body-fill;
        border-width: 2px;
        border-color: root.executing-remotely ? #40c040 : root.remote-controlled ? #4080ff : root.body-edge;
        drop-shadow-color: root.executing-remotely ? #40c04080 : root.remote-controlled ? #4080ff80 : transparent;
        drop-shadow-blur: root.remote-controlled || root.executing-remotely ? 8px : 0px;

        // Inner bevel
        Rectangle {
            x: root.inner-margin; y: root.inner-margin;
            width: parent.width - 2 * root.inner-margin;
            height: parent.height - 2 * root.inner-margin;
            border-radius: Math.max(0px, parent.body-r - root.inner-margin);
            background: root.body-inner;
            border-width: 1px;
            border-color: root.dark-mode ? #1a1a20 : #b8b2ac;

            VerticalLayout {
                padding: root.layout-padding;
                spacing: root.layout-spacing;

                // ---- Solar panel strip ----
                Rectangle {
                    height: root.solar-h;
                    border-radius: Math.max(1px, root.solar-h * 0.2);
                    background: root.solar-fill;
                    HorizontalLayout {
                        padding: 1px;
                        spacing: 1px;
                        for _i in 8: Rectangle { background: root.solar-cell; border-radius: 1px; }
                    }
                }

                // ---- Brand label ----
                Text {
                    text: "AR7778  语音计算器";
                    font-size: root.brand-font-size;
                    font-weight: 700;
                    color: root.dark-mode ? #505060 : #8a8480;
                    horizontal-alignment: left;
                    letter-spacing: 1px;
                    height: root.brand-h;
                }

                // ---- Status bar ----
                StatusBar {
                    height: root.status-h;
                    memory-indicator: root.memory-indicator;
                    audio-status: root.audio-status;
                    mode-indicator: root.mode-indicator;
                    network-status: root.network-status;
                    dark-mode: root.dark-mode;
                    remote-controlled: root.remote-controlled;
                    executing-remotely: root.executing-remotely;
                    status-font-size: root.status-font-size;
                    status-icon-sz: root.status-icon-sz;
                    layout-spacing: root.layout-spacing;
                    status-fg: root.status-fg;
                    status-hover: root.status-hover;
                    btn-memory: root.btn-memory;
                    toggle-theme => { root.toggle-theme(); }
                    switch-audio-mode => { root.switch-audio-mode(); }
                    show-about => { root.show-about(); }
                    show-network-settings => { root.show-network-settings(); }
                    show-settings => { root.show-settings(); }
                }

                // ---- Volume slider with mute toggle ----
                HorizontalLayout {
                    height: root.volume-h;
                    spacing: root.layout-spacing;
                    Text { text: "\u{F027}"; font-family: "JetBrainsMono Nerd Font"; font-size: root.status-font-size; vertical-alignment: center; color: root.status-fg; }
                    // Mute toggle button
                    Rectangle {
                        width: self.height;
                        background: touch.pressed ? #80808040 : touch.has-hover ? #80808020 : transparent;
                        border-radius: self.height * 0.2;
                        touch := TouchArea {
                            clicked => { root.toggle-mute(); }
                        }
                        Text {
                            text: root.audio-muted ? "\u{F026}" : "\u{F027}";
                            font-family: "JetBrainsMono Nerd Font";
                            font-size: root.status-font-size;
                            vertical-alignment: center;
                            horizontal-alignment: center;
                            color: root.audio-muted ? root.btn-clear : root.status-fg;
                        }
                    }
                    Slider {
                        minimum: 0;
                        maximum: 100;
                        value: 50;
                        changed => { root.volume-changed(self.value / 100.0); }
                    }
                    Text { text: "\u{F028}"; font-family: "JetBrainsMono Nerd Font"; font-size: root.status-font-size; vertical-alignment: center; color: root.status-fg; }
                }

                // ---- History ----
                Text { text: root.history-text; font-size: root.status-font-size; color: root.status-fg; horizontal-alignment: right; height: root.history-h; }

                // ---- LCD Display ----
                LcdDisplay {
                    height: root.lcd-h;
                    display-text: root.display-text;
                    error-state: root.error-state;
                    lcd-bg: root.lcd-bg;
                    lcd-fg: root.lcd-fg;
                    lcd-frame: root.lcd-frame;
                    lcd-error-bg: root.lcd-error-bg;
                    lcd-error-fg: root.lcd-error-fg;
                    lcd-font-size: root.lcd-font-size;
                    status-font-size: root.status-font-size;
                    layout-padding: root.layout-padding;
                }

                // ---- Button grid (GridLayout for adaptive sizing) ----
                GridLayout {
                    spacing: root.layout-spacing;
                    vertical-stretch: 1;

                    // Row: MC  MR  M-  M+
                    Row {
                        SkeuBtn { label: "MC"; base: root.btn-func; fg: root.btn-func-fg; font-size: root.btn-font-size; keyboard-active: root.keyboard-pressed && root.last-keyboard-action == "memory-clear"; clicked => { root.memory-clear(); } }
                        SkeuBtn { label: "MR"; base: root.btn-func; fg: root.btn-func-fg; font-size: root.btn-font-size; keyboard-active: root.keyboard-pressed && root.last-keyboard-action == "memory-recall"; clicked => { root.memory-recall(); } }
                        SkeuBtn { label: "M-"; base: root.btn-func; fg: root.btn-func-fg; font-size: root.btn-font-size; keyboard-active: root.keyboard-pressed && root.last-keyboard-action == "memory-subtract"; clicked => { root.memory-subtract(); } }
                        SkeuBtn { label: "M+"; base: root.btn-func; fg: root.btn-func-fg; font-size: root.btn-font-size; clicked => { root.memory-add(); } }
                    }

                    // Row: %  √  MU (span 2)
                    Row {
                        SkeuBtn { label: "%"; base: root.btn-func; fg: root.btn-func-fg; font-size: root.btn-font-size; keyboard-active: root.keyboard-pressed && root.last-keyboard-action == "percent"; clicked => { root.percent(); } }
                        SkeuBtn { label: "\u{221A}"; base: root.btn-func; fg: root.btn-func-fg; font-size: root.btn-font-size; keyboard-active: root.keyboard-pressed && root.last-keyboard-action == "sqrt"; clicked => { root.square-root(); } }
                        SkeuBtn { colspan: 2; label: "MU"; base: root.btn-func; fg: root.btn-func-fg; font-size: root.btn-font-size; keyboard-active: root.keyboard-pressed && root.last-keyboard-action == "mu"; clicked => { root.mu(); } }
                    }

                    // Row: AC  C  ⌫  ÷
                    Row {
                        SkeuBtn { label: "AC"; base: root.btn-clear; fg: root.btn-clear-fg; font-size: root.btn-font-size; keyboard-active: root.keyboard-pressed && root.last-keyboard-action == "all-clear"; clicked => { root.all-clear(); } }
                        SkeuBtn { label: "C"; base: root.btn-ci; fg: root.btn-ci-fg; font-size: root.btn-font-size; keyboard-active: root.keyboard-pressed && root.last-keyboard-action == "clear"; clicked => { root.clear-input(); } }
                        // Backspace button (Nerd Font glyph)
                        SkeuBtn { icon: "\u{232B}"; base: root.btn-bs; fg: root.btn-bs-fg; font-size: root.btn-font-size; keyboard-active: root.keyboard-pressed && root.last-keyboard-action == "backspace"; clicked => { root.backspace(); } }
                        SkeuBtn { label: "\u{00F7}"; base: root.btn-op; fg: root.btn-op-fg; font-size: root.btn-font-size; keyboard-active: root.keyboard-pressed && root.last-keyboard-action == "divide"; clicked => { root.operator-pressed("/"); } }
                    }

                    // Row: 7  8  9  ×
                    Row {
                        SkeuBtn { label: "7"; base: root.btn-digit; fg: root.btn-digit-fg; font-size: root.btn-font-size; keyboard-active: root.keyboard-pressed && root.last-keyboard-action == "digit:7"; clicked => { root.digit-pressed(7); } }
                        SkeuBtn { label: "8"; base: root.btn-digit; fg: root.btn-digit-fg; font-size: root.btn-font-size; keyboard-active: root.keyboard-pressed && root.last-keyboard-action == "digit:8"; clicked => { root.digit-pressed(8); } }
                        SkeuBtn { label: "9"; base: root.btn-digit; fg: root.btn-digit-fg; font-size: root.btn-font-size; keyboard-active: root.keyboard-pressed && root.last-keyboard-action == "digit:9"; clicked => { root.digit-pressed(9); } }
                        SkeuBtn { label: "\u{00D7}"; base: root.btn-op; fg: root.btn-op-fg; font-size: root.btn-font-size; keyboard-active: root.keyboard-pressed && root.last-keyboard-action == "multiply"; clicked => { root.operator-pressed("*"); } }
                    }

                    // Row: 4  5  6  -
                    Row {
                        SkeuBtn { label: "4"; base: root.btn-digit; fg: root.btn-digit-fg; font-size: root.btn-font-size; keyboard-active: root.keyboard-pressed && root.last-keyboard-action == "digit:4"; clicked => { root.digit-pressed(4); } }
                        SkeuBtn { label: "5"; base: root.btn-digit; fg: root.btn-digit-fg; font-size: root.btn-font-size; keyboard-active: root.keyboard-pressed && root.last-keyboard-action == "digit:5"; clicked => { root.digit-pressed(5); } }
                        SkeuBtn { label: "6"; base: root.btn-digit; fg: root.btn-digit-fg; font-size: root.btn-font-size; keyboard-active: root.keyboard-pressed && root.last-keyboard-action == "digit:6"; clicked => { root.digit-pressed(6); } }
                        SkeuBtn { label: "-"; base: root.btn-op; fg: root.btn-op-fg; font-size: root.btn-font-size; keyboard-active: root.keyboard-pressed && root.last-keyboard-action == "subtract"; clicked => { root.operator-pressed("-"); } }
                    }

                    // Row: 1  2  3  +
                    Row {
                        SkeuBtn { label: "1"; base: root.btn-digit; fg: root.btn-digit-fg; font-size: root.btn-font-size; keyboard-active: root.keyboard-pressed && root.last-keyboard-action == "digit:1"; clicked => { root.digit-pressed(1); } }
                        SkeuBtn { label: "2"; base: root.btn-digit; fg: root.btn-digit-fg; font-size: root.btn-font-size; keyboard-active: root.keyboard-pressed && root.last-keyboard-action == "digit:2"; clicked => { root.digit-pressed(2); } }
                        SkeuBtn { label: "3"; base: root.btn-digit; fg: root.btn-digit-fg; font-size: root.btn-font-size; keyboard-active: root.keyboard-pressed && root.last-keyboard-action == "digit:3"; clicked => { root.digit-pressed(3); } }
                        SkeuBtn { label: "+"; base: root.btn-op; fg: root.btn-op-fg; font-size: root.btn-font-size; keyboard-active: root.keyboard-pressed && root.last-keyboard-action == "add"; clicked => { root.operator-pressed("+"); } }
                    }

                    // Row: ±  0  .  =
                    Row {
                        SkeuBtn { label: "\u{00B1}"; base: root.btn-func; fg: root.btn-func-fg; font-size: root.btn-font-size; keyboard-active: root.keyboard-pressed && root.last-keyboard-action == "plus-minus"; clicked => { root.plus-minus(); } }
                        SkeuBtn { label: "0"; base: root.btn-digit; fg: root.btn-digit-fg; font-size: root.btn-font-size; keyboard-active: root.keyboard-pressed && root.last-keyboard-action == "digit:0"; clicked => { root.digit-pressed(0); } }
                        SkeuBtn { label: "."; base: root.btn-digit; fg: root.btn-digit-fg; font-size: root.btn-font-size; keyboard-active: root.keyboard-pressed && root.last-keyboard-action == "decimal-point"; clicked => { root.decimal-point(); } }
                        SkeuBtn { label: "="; base: root.btn-eq; fg: root.btn-eq-fg; font-size: root.btn-font-size; keyboard-active: root.keyboard-pressed && root.last-keyboard-action == "equals"; clicked => { root.equals(); } }
                    }
                }
            }

            // =============================================================
            // Network Settings Overlay
            // =============================================================
            if root.network-panel-visible: NetworkPanel {
                x: 0; y: 0;
                width: parent.width;
                height: parent.height;
                dark-mode: root.dark-mode;
                body-fill: root.body-fill;
                body-edge: root.body-edge;
                body-inner: root.body-inner;
                status-fg: root.status-fg;
                status-hover: root.status-hover;
                network-status: root.network-status;
                remote-controlled: root.remote-controlled;
                executing-remotely: root.executing-remotely;
                connection-info: root.connection-info;
                peers: root.peers;
                scanning: root.scanning;
                allow-remote-control: root.allow-remote-control;
                matrix-size: root.matrix-size;
                peer-names: root.peer-names;
                my-index: root.my-index;
                matrix-cells: root.matrix-cells;
                audio-muted: root.audio-muted;
                layout-padding: root.layout-padding;
                layout-spacing: root.layout-spacing;
                status-h: root.status-h;
                status-icon-sz: root.status-icon-sz;
                status-font-size: root.status-font-size;
                close-network-settings => { root.close-network-settings(); }
                connect-to-peer(nid) => { root.connect-to-peer(nid); }
                disconnect-peer(nid) => { root.disconnect-peer(nid); }
                scan-peers => { root.scan-peers(); }
                toggle-remote-control => { root.toggle-remote-control(); }
                route-toggled(r, c, v) => { root.route-toggled(r, c, v); }
                toggle-mute => { root.toggle-mute(); }
            }

            // =============================================================
            // Settings Overlay
            // =============================================================
            if root.settings-panel-visible: SettingsPanel {
                x: 0; y: 0;
                width: parent.width;
                height: parent.height;
                dark-mode: root.dark-mode;
                body-fill: root.body-fill;
                body-edge: root.body-edge;
                body-inner: root.body-inner;
                status-fg: root.status-fg;
                status-hover: root.status-hover;
                btn-func: root.btn-func;
                btn-func-fg: root.btn-func-fg;
                btn-op: root.btn-op;
                btn-op-fg: root.btn-op-fg;
                layout-padding: root.layout-padding;
                layout-spacing: root.layout-spacing;
                status-h: root.status-h;
                status-icon-sz: root.status-icon-sz;
                status-font-size: root.status-font-size;
                display-name: root.settings-display-name;
                save-status: root.settings-save-status;
                close-settings => { root.close-settings(); }
                save-display-name(name) => { root.save-display-name(name); }
            }

            // =============================================================
            // About Dialog (conditionally shown)
            // =============================================================
            if root.about-visible: AboutDialog {
                app-version: root.app-version;
                close-about => { root.close-about(); }
            }
        }
    }

    // ---- Keyboard input handler ----
    // FocusScope receives keyboard focus via forward-focus above.
    // Modifier-held and NetworkPanel-visible checks gate all input.
    // Key-to-action mapping: each branch maps a key (or key group)
    // to the corresponding action string consumed by keyboard-action.
    kbd-focus := FocusScope {
        property <bool> last-key-accepted: false;

        key-pressed(event) => {
            if event.modifiers.control || event.modifiers.alt || event.modifiers.meta {
                last-key-accepted = false; reject
            } else if root.network-panel-visible {
                last-key-accepted = false; reject
            } else if root.settings-panel-visible {
                last-key-accepted = false; reject
            } else if root.about-visible {
                if event.text == "\u{001b}" {
                    root.close-about(); last-key-accepted = true; accept
                } else {
                    last-key-accepted = false; reject
                }
            } else if event.text == "0" {
                root.last-keyboard-action = "digit:0"; root.keyboard-pressed = true; root.keyboard-action("digit:0"); last-key-accepted = true; accept
            } else if event.text == "1" {
                root.last-keyboard-action = "digit:1"; root.keyboard-pressed = true; root.keyboard-action("digit:1"); last-key-accepted = true; accept
            } else if event.text == "2" {
                root.last-keyboard-action = "digit:2"; root.keyboard-pressed = true; root.keyboard-action("digit:2"); last-key-accepted = true; accept
            } else if event.text == "3" {
                root.last-keyboard-action = "digit:3"; root.keyboard-pressed = true; root.keyboard-action("digit:3"); last-key-accepted = true; accept
            } else if event.text == "4" {
                root.last-keyboard-action = "digit:4"; root.keyboard-pressed = true; root.keyboard-action("digit:4"); last-key-accepted = true; accept
            } else if event.text == "5" {
                root.last-keyboard-action = "digit:5"; root.keyboard-pressed = true; root.keyboard-action("digit:5"); last-key-accepted = true; accept
            } else if event.text == "6" {
                root.last-keyboard-action = "digit:6"; root.keyboard-pressed = true; root.keyboard-action("digit:6"); last-key-accepted = true; accept
            } else if event.text == "7" {
                root.last-keyboard-action = "digit:7"; root.keyboard-pressed = true; root.keyboard-action("digit:7"); last-key-accepted = true; accept
            } else if event.text == "8" {
                root.last-keyboard-action = "digit:8"; root.keyboard-pressed = true; root.keyboard-action("digit:8"); last-key-accepted = true; accept
            } else if event.text == "9" {
                root.last-keyboard-action = "digit:9"; root.keyboard-pressed = true; root.keyboard-action("digit:9"); last-key-accepted = true; accept
            } else if event.text == "+" {
                root.last-keyboard-action = "add"; root.keyboard-pressed = true; root.keyboard-action("add"); last-key-accepted = true; accept
            } else if event.text == "-" {
                root.last-keyboard-action = "subtract"; root.keyboard-pressed = true; root.keyboard-action("subtract"); last-key-accepted = true; accept
            } else if event.text == "*" {
                root.last-keyboard-action = "multiply"; root.keyboard-pressed = true; root.keyboard-action("multiply"); last-key-accepted = true; accept
            } else if event.text == "/" {
                root.last-keyboard-action = "divide"; root.keyboard-pressed = true; root.keyboard-action("divide"); last-key-accepted = true; accept
            } else if event.text == "\u{000d}" || event.text == "\u{000a}" {
                root.last-keyboard-action = "equals"; root.keyboard-pressed = true; root.keyboard-action("equals"); last-key-accepted = true; accept
            } else if event.text == "." {
                root.last-keyboard-action = "decimal-point"; root.keyboard-pressed = true; root.keyboard-action("decimal-point"); last-key-accepted = true; accept
            } else if event.text == "\u{0008}" {
                root.last-keyboard-action = "backspace"; root.keyboard-pressed = true; root.keyboard-action("backspace"); last-key-accepted = true; accept
            } else if event.text == "\u{001b}" {
                root.last-keyboard-action = "all-clear"; root.keyboard-pressed = true; root.keyboard-action("all-clear"); last-key-accepted = true; accept
            } else if event.text == "\u{007f}" {
                root.last-keyboard-action = "clear"; root.keyboard-pressed = true; root.keyboard-action("clear"); last-key-accepted = true; accept
            } else if event.text == "%" {
                root.last-keyboard-action = "percent"; root.keyboard-pressed = true; root.keyboard-action("percent"); last-key-accepted = true; accept
            } else if event.text == "s" || event.text == "S" {
                root.last-keyboard-action = "sqrt"; root.keyboard-pressed = true; root.keyboard-action("sqrt"); last-key-accepted = true; accept
            } else if event.text == "m" || event.text == "M" {
                root.last-keyboard-action = "memory-recall"; root.keyboard-pressed = true; root.keyboard-action("memory-recall"); last-key-accepted = true; accept
            } else if event.text == "c" || event.text == "C" {
                root.last-keyboard-action = "memory-clear"; root.keyboard-pressed = true; root.keyboard-action("memory-clear"); last-key-accepted = true; accept
            } else if event.text == "u" || event.text == "U" {
                root.last-keyboard-action = "mu"; root.keyboard-pressed = true; root.keyboard-action("mu"); last-key-accepted = true; accept
            } else if event.text == "b" || event.text == "B" {
                root.last-keyboard-action = "memory-subtract"; root.keyboard-pressed = true; root.keyboard-action("memory-subtract"); last-key-accepted = true; accept
            } else if event.text == "n" || event.text == "N" {
                root.last-keyboard-action = "plus-minus"; root.keyboard-pressed = true; root.keyboard-action("plus-minus"); last-key-accepted = true; accept
            } else {
                last-key-accepted = false; reject
            }
        }

        key-released(event) => {
            if (last-key-accepted) { root.keyboard-pressed = false; accept; }
            else { reject; }
        }
    }
}

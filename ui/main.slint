import { VerticalBox, Slider } from "std-widgets.slint";
import "../resource/fonts/NotoSansSC-Regular.otf";
import "../resource/fonts/JetBrainsMonoNerdFont-Regular.ttf";

// =====================================================================
// Skeuomorphic Calculator – GridLayout-based adaptive layout
// Inspired by Casio SL-300 / Eltex 2000 / Neumorphic calculators
// =====================================================================

// ---- Skeuomorphic button with gradient bevel ----
component SkeuBtn inherits Rectangle {
    in property <string> label;
    in property <brush> base: #c8c8c8;
    in property <brush> fg: #333;
    in property <length> font-size: 16px;
    callback clicked;

    // Scaling border-radius: ~28% of the shorter side, preserves roundness at any size
    border-radius: Math.min(self.width, self.height) * 0.28;
    border-width: 1px;
    border-color: ta.pressed ? base.darker(40%) : base.darker(25%);

    // Convex bevel via linear gradient: lighter top, darker bottom.
    // No child elements needed — the gradient follows the rounded outline naturally.
    background: ta.pressed
        ? base.darker(15%)
        : ta.has-hover
            ? @linear-gradient(180deg, base.brighter(12%) 0%, base 40%, base.darker(8%) 100%)
            : @linear-gradient(180deg, base.brighter(18%) 0%, base.brighter(3%) 35%, base.darker(5%) 100%);

    ta := TouchArea { clicked => { root.clicked(); } }

    Text {
        text: root.label;
        font-size: root.font-size;
        color: root.fg;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

// ---- Peer info for network overlay ----
struct PeerInfoSlint {
    name: string,
    address: string,
    is-connected: bool,
    latency-ms: int,
    index: int,
}

// ---- About Dialog ----
export component AboutDialog inherits Dialog {
    title: "关于";
    preferred-width: 320px;
    preferred-height: 200px;
    VerticalBox {
        Text { text: "语音计算器 v0.1.0"; font-size: 16px; font-weight: 700; horizontal-alignment: center; }
        Text { text: "界面: Slint | 音频: kira | 精度: rust_decimal"; font-size: 11px; horizontal-alignment: center; color: #666; wrap: word-wrap; }
        Text { text: "Slint 社区许可证"; font-size: 10px; horizontal-alignment: center; color: #999; }
    }
}

// ---- Main calculator window ----
export component CalculatorWindow inherits Window {
    default-font-family: "Noto Sans SC";
    preferred-width: 380px;
    preferred-height: 700px;
    min-width: 260px;
    min-height: 460px;
    title: "语音计算器";

    // ---- Scalable font sizes (derived from window height, with floor) ----
    property <length> btn-font-size: Math.max(12px, self.height * 0.025);
    property <length> lcd-font-size: Math.max(16px, self.height * 0.04);
    property <length> status-font-size: Math.max(10px, self.height * 0.022);
    property <length> icon-font-size: Math.max(20px, self.height * 0.04);
    property <length> brand-font-size: Math.max(10px, self.height * 0.02);

    // ---- Scalable layout dimensions (all proportional to window height) ----
    property <length> body-margin: Math.max(4px, self.height * 0.014);
    property <length> inner-margin: Math.max(2px, self.height * 0.004);
    property <length> solar-h: Math.max(4px, self.height * 0.014);
    property <length> brand-h: Math.max(8px, self.height * 0.023);
    property <length> status-h: Math.max(24px, self.height * 0.055);
    property <length> icon-sz: Math.max(36px, self.height * 0.075);
    property <length> status-icon-sz: Math.max(18px, self.height * 0.035);
    property <length> volume-h: Math.max(20px, self.height * 0.045);
    property <length> history-h: Math.max(10px, self.height * 0.022);
    property <length> lcd-h: Math.max(40px, self.height * 0.1);
    property <length> layout-spacing: Math.max(2px, self.height * 0.005);
    property <length> layout-padding: Math.max(4px, self.height * 0.011);

    // Theme
    in-out property <bool> dark-mode: false;
    background: dark-mode ? #1a1a1e : #e8e4e0;

    // Data properties
    in property <string> display-text: "0";
    in property <string> memory-indicator: "";
    in property <string> mode-indicator: "普通";
    in property <bool> error-state: false;
    in property <string> history-text: "";
    in property <string> audio-status: "";

    // Network status (Phase 5)
    in property <string> network-status: "";
    in property <bool> remote-controlled: false;
    in property <bool> executing-remotely: false;
    in property <string> connection-info: "";
    in property <bool> network-panel-visible: false;
    in property <[PeerInfoSlint]> peers;
    in property <int> connected-peer-index: -1;
    in property <bool> scanning: false;

    // ---- Skeuomorphic color palette ----
    property <brush> body-fill: dark-mode ? #2a2a30 : #c0bab4;
    property <brush> body-edge: dark-mode ? #3a3a42 : #a8a29c;
    property <brush> body-inner: dark-mode ? #222228 : #d4cec8;
    property <brush> lcd-bg: dark-mode ? #2a3a2a : #b8c890;
    property <brush> lcd-fg: dark-mode ? #a0d0a0 : #2a3a1a;
    property <brush> lcd-frame: dark-mode ? #1a1a20 : #606850;
    property <brush> lcd-error-bg: dark-mode ? #3a2020 : #e8b0a0;
    property <brush> lcd-error-fg: dark-mode ? #ff8080 : #8a2020;
    property <brush> solar-fill: dark-mode ? #0a0a12 : #1a1a2a;
    property <brush> solar-cell: dark-mode ? #1a1a28 : #0a0a18;
    property <brush> btn-digit: dark-mode ? #3a3a42 : #d8d4d0;
    property <brush> btn-digit-fg: dark-mode ? #d0d0d0 : #2a2a2a;
    property <brush> btn-op: dark-mode ? #5a4020 : #e8a848;
    property <brush> btn-op-fg: dark-mode ? #ffd090 : #3a2a10;
    property <brush> btn-func: dark-mode ? #303038 : #b0aca8;
    property <brush> btn-func-fg: dark-mode ? #a0a0a0 : #4a4a4a;
    property <brush> btn-clear: dark-mode ? #5a2020 : #d06050;
    property <brush> btn-clear-fg: dark-mode ? #ffaaaa : #ffffff;
    property <brush> btn-ci: dark-mode ? #4a3520 : #d08868;
    property <brush> btn-ci-fg: dark-mode ? #ffccaa : #ffffff;
    property <brush> btn-bs: dark-mode ? #4a4020 : #d0b870;
    property <brush> btn-bs-fg: dark-mode ? #ffddaa : #3a2a10;
    property <brush> btn-eq: dark-mode ? #1a4070 : #4080c8;
    property <brush> btn-eq-fg: dark-mode ? #90c0ff : #ffffff;
    property <brush> btn-memory: dark-mode ? #4a2020 : #c04040;
    property <brush> status-fg: dark-mode ? #808090 : #706860;
    property <brush> status-hover: dark-mode ? #3a3a42 : #c0bab4;

    // Callbacks
    callback digit-pressed(int);
    callback decimal-point();
    callback operator-pressed(string);
    callback equals();
    callback percent();
    callback mu();
    callback square-root();
    callback backspace();
    callback clear-input();
    callback all-clear();
    callback plus-minus();
    callback memory-recall();
    callback memory-add();
    callback memory-subtract();
    callback memory-clear();
    callback switch-audio-mode();
    callback show-about();
    callback toggle-theme();
    callback volume-changed(float);
    callback show-network-settings();
    callback close-network-settings();
    callback connect-to-peer(int);
    callback disconnect-peer(int);
    callback scan-peers();

    // =================================================================
    // Body
    // =================================================================
    Rectangle {
        x: root.body-margin; y: root.body-margin;
        width: parent.width - 2 * root.body-margin;
        height: parent.height - 2 * root.body-margin;
        // Scaling body radius
        property <length> body-r: Math.min(self.width, self.height) * 0.03;
        border-radius: self.body-r;
        background: body-fill;
        border-width: 2px;
        border-color: root.executing-remotely ? #40c040 : root.remote-controlled ? #4080ff : body-edge;
        drop-shadow-color: root.executing-remotely ? #40c04080 : root.remote-controlled ? #4080ff80 : transparent;
        drop-shadow-blur: root.remote-controlled || root.executing-remotely ? 8px : 0px;

        // Inner bevel
        Rectangle {
            x: root.inner-margin; y: root.inner-margin;
            width: parent.width - 2 * root.inner-margin;
            height: parent.height - 2 * root.inner-margin;
            border-radius: Math.max(0px, parent.body-r - root.inner-margin);
            background: body-inner;
            border-width: 1px;
            border-color: dark-mode ? #1a1a20 : #b8b2ac;

            VerticalLayout {
                padding: root.layout-padding;
                spacing: root.layout-spacing;

                // ---- Solar panel strip ----
                Rectangle {
                    height: root.solar-h;
                    border-radius: Math.max(1px, root.solar-h * 0.2);
                    background: solar-fill;
                    HorizontalLayout {
                        padding: 1px;
                        spacing: 1px;
                        Rectangle { background: solar-cell; border-radius: 1px; }
                        Rectangle { background: solar-cell; border-radius: 1px; }
                        Rectangle { background: solar-cell; border-radius: 1px; }
                        Rectangle { background: solar-cell; border-radius: 1px; }
                        Rectangle { background: solar-cell; border-radius: 1px; }
                        Rectangle { background: solar-cell; border-radius: 1px; }
                        Rectangle { background: solar-cell; border-radius: 1px; }
                        Rectangle { background: solar-cell; border-radius: 1px; }
                    }
                }

                // ---- Brand label ----
                Text {
                    text: "AR7778  语音计算器";
                    font-size: root.brand-font-size;
                    font-weight: 700;
                    color: dark-mode ? #505060 : #8a8480;
                    horizontal-alignment: left;
                    letter-spacing: 1px;
                    height: root.brand-h;
                }

                // ---- Status bar ----
                HorizontalLayout {
                    height: root.status-h;
                    spacing: root.layout-spacing;
                    padding: 4px;
                    Text { text: root.memory-indicator; font-size: root.status-font-size; color: btn-memory; font-weight: 700; vertical-alignment: center; }
                    Rectangle { horizontal-stretch: 1; }
                    Text { text: root.audio-status; font-size: root.status-font-size; color: status-fg; vertical-alignment: center; }
                    Text { text: " "; font-size: Math.max(6px, root.status-font-size * 0.5); vertical-alignment: center; }
                    Text { text: root.mode-indicator; font-size: root.status-font-size; color: status-fg; vertical-alignment: center; }

                    // Theme toggle
                    Rectangle {
                        width: root.status-icon-sz; height: root.status-icon-sz;
                        border-radius: Math.min(self.width, self.height) * 0.2;
                        background: tt.has-hover ? status-hover : transparent;
                        tt := TouchArea { clicked => { root.toggle-theme(); } }
                        Text {
                            text: root.dark-mode ? "\u{F185}" : "\u{F186}";
                            font-family: "JetBrainsMono Nerd Font";
                            font-size: root.status-font-size;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            color: status-fg;
                        }
                    }
                    // Audio mode
                    Rectangle {
                        width: root.status-icon-sz; height: root.status-icon-sz;
                        border-radius: Math.min(self.width, self.height) * 0.2;
                        background: mt.has-hover ? status-hover : transparent;
                        mt := TouchArea { clicked => { root.switch-audio-mode(); } }
                        Text { text: "\u{F001}"; font-family: "JetBrainsMono Nerd Font"; font-size: root.status-font-size; horizontal-alignment: center; vertical-alignment: center; color: status-fg; }
                    }
                    // About
                    Rectangle {
                        width: root.status-icon-sz; height: root.status-icon-sz;
                        border-radius: Math.min(self.width, self.height) * 0.2;
                        background: at.has-hover ? status-hover : transparent;
                        at := TouchArea { clicked => { root.show-about(); } }
                        Text { text: "\u{F05A}"; font-family: "JetBrainsMono Nerd Font"; font-size: root.status-font-size; horizontal-alignment: center; vertical-alignment: center; color: status-fg; }
                    }
                    // Network status indicator (clickable -> opens settings)
                    Rectangle {
                        width: root.status-icon-sz; height: root.status-icon-sz;
                        border-radius: Math.min(self.width, self.height) * 0.2;
                        background: nt.has-hover ? status-hover : transparent;
                        opacity: root.network-status != "" ? 1.0 : 0.3;
                        nt := TouchArea { clicked => { root.show-network-settings(); } }
                        Text {
                            text: root.executing-remotely ? "\u{F0E7}" : root.remote-controlled ? "\u{F0AC}" : "\u{F0C2}";
                            font-family: "JetBrainsMono Nerd Font";
                            font-size: root.status-font-size;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            color: root.executing-remotely ? #ffa500 : root.remote-controlled ? #40c040 : status-fg;
                        }
                    }
                }

                // ---- Volume slider ----
                HorizontalLayout {
                    height: root.volume-h;
                    spacing: root.layout-spacing;
                    Text { text: "\u{F027}"; font-family: "JetBrainsMono Nerd Font"; font-size: root.status-font-size; vertical-alignment: center; color: status-fg; }
                    Slider {
                        minimum: 0;
                        maximum: 100;
                        value: 50;
                        changed => { root.volume-changed(self.value / 100.0); }
                    }
                    Text { text: "\u{F028}"; font-family: "JetBrainsMono Nerd Font"; font-size: root.status-font-size; vertical-alignment: center; color: status-fg; }
                }

                // ---- History ----
                Text { text: root.history-text; font-size: root.status-font-size; color: status-fg; horizontal-alignment: right; height: root.history-h; }

                // ---- LCD Display ----
                Rectangle {
                    height: root.lcd-h;
                    property <length> lcd-r: Math.min(self.width, self.height) * 0.15;
                    border-radius: self.lcd-r;
                    background: lcd-frame;
                    border-width: 2px;
                    border-color: lcd-frame;

                    Rectangle {
                        x: 3px; y: 3px;
                        width: parent.width - 6px;
                        height: parent.height - 6px;
                        border-radius: Math.max(0px, parent.lcd-r - 3px);
                        background: root.error-state ? lcd-error-bg : lcd-bg;

                        Text {
                            text: root.display-text;
                            font-size: root.error-state ? root.status-font-size : root.lcd-font-size;
                            font-weight: 600;
                            color: root.error-state ? lcd-error-fg : lcd-fg;
                            horizontal-alignment: right;
                            vertical-alignment: center;
                            x: Math.max(4px, root.layout-padding * 0.6);
                            width: parent.width - 2 * Math.max(4px, root.layout-padding * 0.6);
                            overflow: elide;
                        }
                    }
                }

                // ---- Button grid (GridLayout for adaptive sizing) ----
                GridLayout {
                    spacing: root.layout-spacing;
                    vertical-stretch: 1;

                    // Row: MC  MR  M-  M+
                    Row {
                        SkeuBtn { label: "MC"; base: btn-func; fg: btn-func-fg; font-size: root.btn-font-size; clicked => { root.memory-clear(); } }
                        SkeuBtn { label: "MR"; base: btn-func; fg: btn-func-fg; font-size: root.btn-font-size; clicked => { root.memory-recall(); } }
                        SkeuBtn { label: "M-"; base: btn-func; fg: btn-func-fg; font-size: root.btn-font-size; clicked => { root.memory-subtract(); } }
                        SkeuBtn { label: "M+"; base: btn-func; fg: btn-func-fg; font-size: root.btn-font-size; clicked => { root.memory-add(); } }
                    }

                    // Row: %  √  MU (span 2)
                    Row {
                        SkeuBtn { label: "%"; base: btn-func; fg: btn-func-fg; font-size: root.btn-font-size; clicked => { root.percent(); } }
                        SkeuBtn { label: "\u{221A}"; base: btn-func; fg: btn-func-fg; font-size: root.btn-font-size; clicked => { root.square-root(); } }
                        SkeuBtn { colspan: 2; label: "MU"; base: btn-func; fg: btn-func-fg; font-size: root.btn-font-size; clicked => { root.mu(); } }
                    }

                    // Row: AC  C  ⌫  ÷
                    Row {
                        SkeuBtn { label: "AC"; base: btn-clear; fg: btn-clear-fg; font-size: root.btn-font-size; clicked => { root.all-clear(); } }
                        SkeuBtn { label: "C"; base: btn-ci; fg: btn-ci-fg; font-size: root.btn-font-size; clicked => { root.clear-input(); } }
                        // Backspace button (Nerd Font glyph)
                        Rectangle {
                            border-radius: Math.min(self.width, self.height) * 0.28;
                            border-width: 1px;
                            border-color: bsta.pressed ? btn-bs.darker(40%) : btn-bs.darker(25%);
                            background: bsta.pressed
                                ? btn-bs.darker(15%)
                                : bsta.has-hover
                                    ? @linear-gradient(180deg, btn-bs.brighter(12%) 0%, btn-bs 40%, btn-bs.darker(8%) 100%)
                                    : @linear-gradient(180deg, btn-bs.brighter(18%) 0%, btn-bs.brighter(3%) 35%, btn-bs.darker(5%) 100%);
                            bsta := TouchArea { clicked => { root.backspace(); } }
                            Text {
                                text: "\u{232B}";
                                font-size: root.btn-font-size;
                                font-weight: 700;
                                color: btn-bs-fg;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                x: (parent.width - self.width) / 2;
                                y: (parent.height - self.height) / 2;
                            }
                        }
                        SkeuBtn { label: "\u{00F7}"; base: btn-op; fg: btn-op-fg; font-size: root.btn-font-size; clicked => { root.operator-pressed("/"); } }
                    }

                    // Row: 7  8  9  ×
                    Row {
                        SkeuBtn { label: "7"; base: btn-digit; fg: btn-digit-fg; font-size: root.btn-font-size; clicked => { root.digit-pressed(7); } }
                        SkeuBtn { label: "8"; base: btn-digit; fg: btn-digit-fg; font-size: root.btn-font-size; clicked => { root.digit-pressed(8); } }
                        SkeuBtn { label: "9"; base: btn-digit; fg: btn-digit-fg; font-size: root.btn-font-size; clicked => { root.digit-pressed(9); } }
                        SkeuBtn { label: "\u{00D7}"; base: btn-op; fg: btn-op-fg; font-size: root.btn-font-size; clicked => { root.operator-pressed("*"); } }
                    }

                    // Row: 4  5  6  -
                    Row {
                        SkeuBtn { label: "4"; base: btn-digit; fg: btn-digit-fg; font-size: root.btn-font-size; clicked => { root.digit-pressed(4); } }
                        SkeuBtn { label: "5"; base: btn-digit; fg: btn-digit-fg; font-size: root.btn-font-size; clicked => { root.digit-pressed(5); } }
                        SkeuBtn { label: "6"; base: btn-digit; fg: btn-digit-fg; font-size: root.btn-font-size; clicked => { root.digit-pressed(6); } }
                        SkeuBtn { label: "-"; base: btn-op; fg: btn-op-fg; font-size: root.btn-font-size; clicked => { root.operator-pressed("-"); } }
                    }

                    // Row: 1  2  3  +
                    Row {
                        SkeuBtn { label: "1"; base: btn-digit; fg: btn-digit-fg; font-size: root.btn-font-size; clicked => { root.digit-pressed(1); } }
                        SkeuBtn { label: "2"; base: btn-digit; fg: btn-digit-fg; font-size: root.btn-font-size; clicked => { root.digit-pressed(2); } }
                        SkeuBtn { label: "3"; base: btn-digit; fg: btn-digit-fg; font-size: root.btn-font-size; clicked => { root.digit-pressed(3); } }
                        SkeuBtn { label: "+"; base: btn-op; fg: btn-op-fg; font-size: root.btn-font-size; clicked => { root.operator-pressed("+"); } }
                    }

                    // Row: ±  0  .  =
                    Row {
                        SkeuBtn { label: "\u{00B1}"; base: btn-func; fg: btn-func-fg; font-size: root.btn-font-size; clicked => { root.plus-minus(); } }
                        SkeuBtn { label: "0"; base: btn-digit; fg: btn-digit-fg; font-size: root.btn-font-size; clicked => { root.digit-pressed(0); } }
                        SkeuBtn { label: "."; base: btn-digit; fg: btn-digit-fg; font-size: root.btn-font-size; clicked => { root.decimal-point(); } }
                        SkeuBtn { label: "="; base: btn-eq; fg: btn-eq-fg; font-size: root.btn-font-size; clicked => { root.equals(); } }
                    }
                }
            }

            // =============================================================
            // Network Settings Overlay
            // =============================================================
            if root.network-panel-visible: Rectangle {
                x: 0; y: 0;
                width: parent.width;
                height: parent.height;
                background: dark-mode ? #1a1a1ecc : #c0bab4cc;
                border-radius: parent.border-radius;

                // Semi-transparent backdrop touch catcher
                backdrop := TouchArea { clicked => { } }

                // Card
                Rectangle {
                    x: root.layout-padding * 2;
                    y: root.layout-padding * 2;
                    width: parent.width - root.layout-padding * 4;
                    height: parent.height - root.layout-padding * 4;
                    property <length> card-r: Math.min(self.width, self.height) * 0.04;
                    border-radius: self.card-r;
                    background: body-fill;
                    border-width: 1px;
                    border-color: body-edge;

                    // Inner bevel for card
                    Rectangle {
                        x: 2px; y: 2px;
                        width: parent.width - 4px;
                        height: parent.height - 4px;
                        border-radius: Math.max(0px, parent.card-r - 2px);
                        background: body-inner;
                        border-width: 1px;
                        border-color: dark-mode ? #1a1a20 : #b8b2ac;

                        VerticalLayout {
                            padding: root.layout-padding;
                            spacing: root.layout-spacing;

                            // Title bar with close button
                            HorizontalLayout {
                                height: root.status-h;
                                spacing: root.layout-spacing;
                                Text {
                                    text: "\u{F0AC} 网络设置";
                                    font-family: "JetBrainsMono Nerd Font";
                                    font-size: Math.max(12px, root.status-font-size * 1.3);
                                    font-weight: 700;
                                    color: dark-mode ? #d0d0d0 : #2a2a2a;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }
                                // Close button
                                Rectangle {
                                    width: root.status-icon-sz;
                                    height: root.status-icon-sz;
                                    border-radius: Math.min(self.width, self.height) * 0.2;
                                    background: close-ta.has-hover ? status-hover : transparent;
                                    close-ta := TouchArea { clicked => { root.close-network-settings(); } }
                                    Text {
                                        text: "\u{F00D}";
                                        font-family: "JetBrainsMono Nerd Font";
                                        font-size: root.status-font-size;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                        color: status-fg;
                                    }
                                }
                            }

                            // Connection status
                            Rectangle {
                                height: root.status-h;
                                border-radius: Math.min(self.width, self.height) * 0.15;
                                background: dark-mode ? #222228 : #d4cec8;
                                border-width: 1px;
                                border-color: dark-mode ? #3a3a42 : #b8b2ac;
                                HorizontalLayout {
                                    padding: root.layout-padding;
                                    Text {
                                        text: root.network-status != "" ? root.network-status : "未连接";
                                        font-size: root.status-font-size;
                                        color: root.network-status != "" ? (root.executing-remotely ? #40c040 : root.remote-controlled ? #4080ff : status-fg) : (dark-mode ? #808090 : #706860);
                                        vertical-alignment: center;
                                        horizontal-stretch: 1;
                                    }
                                }
                            }

                            // Connection info (if any)
                            if root.connection-info != "": Rectangle {
                                height: root.status-h;
                                border-radius: Math.min(self.width, self.height) * 0.15;
                                background: dark-mode ? #222228 : #d4cec8;
                                border-width: 1px;
                                border-color: dark-mode ? #3a3a42 : #b8b2ac;
                                HorizontalLayout {
                                    padding: root.layout-padding;
                                    Text {
                                        text: root.connection-info;
                                        font-size: root.status-font-size;
                                        color: status-fg;
                                        vertical-alignment: center;
                                        wrap: word-wrap;
                                    }
                                }
                            }

                            // Peer list label + scan button
                            Rectangle {
                                height: root.status-h;
                                HorizontalLayout {
                                    padding: 2px;
                                    spacing: 4px;
                                    Text {
                                        text: root.scanning ? "扫描中..." : "已连接节点";
                                        font-size: root.status-font-size;
                                        font-weight: 600;
                                        color: dark-mode ? #a0a0a0 : #4a4a4a;
                                        vertical-alignment: center;
                                        horizontal-stretch: 1;
                                    }
                                    SkeuBtn {
                                        label: "扫描";
                                        base: dark-mode ? #3a4a3a : #c8d8c8;
                                        fg: dark-mode ? #a0c0a0 : #2a4a2a;
                                        font-size: Math.max(9px, root.status-font-size * 0.9);
                                        width: 56px;
                                        clicked => { root.scan-peers(); }
                                    }
                                }
                            }

                            // Peer list (scrollable, populated from Rust)
                            Rectangle {
                                vertical-stretch: 1;
                                border-radius: Math.min(self.width, self.height) * 0.02;
                                background: dark-mode ? #1a1a20 : #e0dcd8;
                                border-width: 1px;
                                border-color: dark-mode ? #3a3a42 : #b8b2ac;
                                clip: true;

                                // Empty state
                                if root.peers.length == 0: VerticalLayout {
                                    padding: root.layout-padding;
                                    Text {
                                        text: "暂无节点连接";
                                        font-size: root.status-font-size;
                                        color: dark-mode ? #606070 : #908880;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }

                                // Peer list
                                if root.peers.length > 0: Flickable {
                                    VerticalLayout {
                                        padding: root.layout-padding;
                                        spacing: 4px;

                                        for peer[i] in root.peers: Rectangle {
                                            height: 48px;
                                            border-radius: Math.min(self.width, self.height) * 0.15;
                                            background: peer.is-connected
                                                ? (dark-mode ? #1a3020 : #d8eed8)
                                                : (dark-mode ? #222228 : #ece8e4);
                                            border-width: 1px;
                                            border-color: peer.is-connected
                                                ? (dark-mode ? #2a5030 : #a0c8a0)
                                                : (dark-mode ? #3a3a42 : #d0ccc8);

                                            HorizontalLayout {
                                                padding: 8px;
                                                spacing: 8px;

                                                // Device icon (Nerd Font)
                                                Text {
                                                    text: peer.is-connected ? "\u{F0E7}" : "\u{F108}";
                                                    font-family: "JetBrainsMono Nerd Font";
                                                    font-size: Math.max(14px, root.status-font-size * 1.3);
                                                    color: peer.is-connected
                                                        ? (dark-mode ? #40c040 : #208020)
                                                        : (dark-mode ? #606070 : #908880);
                                                    vertical-alignment: center;
                                                    width: 24px;
                                                }

                                                // Name and address
                                                VerticalLayout {
                                                    horizontal-stretch: 1;
                                                    spacing: 2px;
                                                    alignment: center;
                                                    Text {
                                                        text: peer.name;
                                                        font-size: root.status-font-size;
                                                        font-weight: 600;
                                                        color: dark-mode ? #d0d0d0 : #2a2a2a;
                                                        overflow: elide;
                                                    }
                                                    Text {
                                                        text: peer.address;
                                                        font-size: Math.max(8px, root.status-font-size * 0.8);
                                                        color: dark-mode ? #707080 : #807870;
                                                        overflow: elide;
                                                    }
                                                }

                                                // Latency indicator (shown when connected)
                                                if peer.is-connected && peer.latency-ms >= 0: Text {
                                                    text: peer.latency-ms < 100 ? "快" : peer.latency-ms < 300 ? "中" : "慢";
                                                    font-size: Math.max(8px, root.status-font-size * 0.8);
                                                    color: peer.latency-ms < 100 ? #40c040 : peer.latency-ms < 300 ? #ffa500 : #ff4040;
                                                    vertical-alignment: center;
                                                }

                                                // Connect / Disconnect button
                                                Rectangle {
                                                    width: 56px;
                                                    height: 28px;
                                                    border-radius: Math.min(self.width, self.height) * 0.3;
                                                    border-width: 1px;
                                                    background: peer.is-connected
                                                        ? (peer-btn-ta.pressed
                                                            ? #3a1818
                                                            : peer-btn-ta.has-hover
                                                                ? #5a2828
                                                                : #4a2020)
                                                        : (peer-btn-ta.pressed
                                                            ? #1a3a68
                                                            : peer-btn-ta.has-hover
                                                                ? #2a5a98
                                                                : #3a70b8);
                                                    border-color: peer.is-connected
                                                        ? (dark-mode ? #804040 : #a06060)
                                                        : (dark-mode ? #5080b0 : #2868a8);

                                                    peer-btn-ta := TouchArea {
                                                        clicked => {
                                                            if (peer.is-connected) {
                                                                root.disconnect-peer(peer.index);
                                                            } else {
                                                                root.connect-to-peer(peer.index);
                                                            }
                                                        }
                                                    }

                                                    Text {
                                                        text: peer.is-connected ? "断开" : "连接";
                                                        font-size: Math.max(9px, root.status-font-size * 0.85);
                                                        font-weight: 600;
                                                        color: peer.is-connected ? #ffaaaa : #ffffff;
                                                        horizontal-alignment: center;
                                                        vertical-alignment: center;
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
